# GitHub Personal Access Token (classic) with scopes:
#   manage_billing:copilot, read:org, read:enterprise
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Enterprise slug — auto-discovers all orgs under it
ENTERPRISE_SLUG=my-enterprise

# OR: Comma-separated list of GitHub organization slugs (overrides enterprise)
# ORGS=my-org-1,my-org-2

# Metrics window in days (default: 28)
# DAYS=28

# Output directory for CSV files (default: current directory)
# OUTPUT_DIR=./reports
